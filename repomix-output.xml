        .menu-tab.active { color: #b8860b; border-bottom: 2px solid #b8860b; font-weight: 500; }
        .menu-tab:hover:not(.active) { color: #333; }
        .search-row { display: flex; gap: 10px; margin-bottom: 1.5rem; }
        .search-input { flex: 1; border: 0.5px solid #e0e0e0; border-radius: 8px; padding: 0.5rem 0.75rem; font-family: 'DM Sans', sans-serif; font-size: 13px; outline: none; }
        .search-input:focus { border-color: #b8860b; }
        .section-title { font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 400; font-style: italic; margin-bottom: 1.5rem; padding-bottom: 0.75rem; border-bottom: 0.5px solid #e0e0e0; display: flex; align-items: baseline; gap: 10px; }
        .section-count { font-family: 'DM Sans', sans-serif; font-size: 12px; font-style: normal; color: #999; font-weight: 400; }
        .dish-row { display: flex; align-items: flex-start; gap: 1rem; padding: 1.25rem 0; border-bottom: 0.5px solid #f0f0f0; cursor: pointer; transition: background 0.15s; border-radius: 4px; }
        .dish-row:last-child { border-bottom: none; }
        .dish-row:hover { background: #f9f9f9; }
        .dish-emoji { width: 72px; height: 72px; border-radius: 8px; background: #f5f5f5; display: flex; align-items: center; justify-content: center; font-size: 28px; flex-shrink: 0; }
        .dish-content { flex: 1; min-width: 0; }
        .dish-header { display: flex; align-items: baseline; justify-content: space-between; gap: 0.5rem; margin-bottom: 4px; }
        .dish-name { font-family: 'Playfair Display', serif; font-size: 1.05rem; font-weight: 400; }
        .dish-price { font-size: 15px; font-weight: 500; color: #b8860b; white-space: nowrap; }
        .dish-desc { font-size: 13px; color: #777; line-height: 1.5; font-weight: 300; }
        .tag { font-size: 10px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; padding: 2px 8px; border-radius: 20px; margin-top: 8px; display: inline-block; margin-right: 4px; }
        .tag-available { background: #eaf3de; color: #27500a; border: 0.5px solid #c0dd97; }
        .tag-unavailable { background: #fcebeb; color: #791f1f; border: 0.5px solid #f09595; }
        .dish-expanded { background: #f9f9f9; border-radius: 8px; padding: 1rem; margin-top: 0.75rem; font-size: 13px; color: #666; }
        .badge-live { display: inline-flex; align-items: center; gap: 5px; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; background: #f5f5f5; border: 0.5px solid #e0e0e0; border-radius: 20px; padding: 2px 10px; color: #999; margin-top: 1.5rem; font-weight: 500; }
        .dot-live { width: 6px; height: 6px; border-radius: 50%; background: #3b6d11; }
        .empty-state { text-align: center; padding: 3rem 1rem; color: #999; font-size: 14px; }
      `}</style>

            <div className="menu-hero">
                <div className="hero-eyebrow">Göteborg · Sedan 1987</div>
                <h1 className="hero-title">Trattoria Bella</h1>
                <div className="hero-divider">✦</div>
                <div className="hero-sub">Autentiskt kök från Toscana — tillagat med kärlek varje dag</div>
            </div>

            <div className="menu-body">
                <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', flexWrap: 'wrap', gap: '0.5rem' }}>
                    <span className="badge-live"><span className="dot-live"></span>Live från backend API</span>
                    <span style={{ fontSize: '12px', color: '#999' }}>{menuItems.length} rätter totalt</span>
                </div>

                <div className="menu-tabs">
                    <button className={`menu-tab ${activeTab === 'alla' ? 'active' : ''}`} onClick={() => setActiveTab('alla')}>Alla rätter</button>
                    {categories.map(cat => (
                        <button
                            key={cat.id}
                            className={`menu-tab ${activeTab === cat.id ? 'active' : ''}`}
                            onClick={() => setActiveTab(cat.id)}
                        >
                            {cat.name}
                        </button>
                    ))}
                </div>

                <div className="search-row">
                    <input
                        className="search-input"
                        type="text"
                        placeholder="Sök rätt..."
                        value={search}
                        onChange={(e) => setSearch(e.target.value)}
                    />
                </div>

                {filtered.length === 0 && (
                    <div className="empty-state">Inga rätter matchar din sökning.</div>
                )}

                {activeTab === 'alla' ? (
                    grouped.map(cat => (
                        <div key={cat.id} style={{ marginBottom: '2.5rem' }}>
                            <div className="section-title">
                                {cat.name} <span className="section-count">{cat.items.length} rätter</span>
                            </div>
                            <div>
                                {cat.items.map(item => (
                                    <DishRow key={item.id} item={item} open={openItem === item.id} onToggle={() => toggleItem(item.id)} />
                                ))}
                            </div>
                        </div>
                    ))
                ) : (
                    <div>
                        {filtered.map(item => (
                            <DishRow key={item.id} item={item} open={openItem === item.id} onToggle={() => toggleItem(item.id)} />
                        ))}
                    </div>
                )}
            </div>
        </div>
    )
}

const categoryEmojis = {
    1: '🍕', 2: '🍝', 3: '🥗', 4: '🍞', 5: '🥩', 6: '🍮', 7: '🥤', 8: '🍷'
}

function DishRow({ item, open, onToggle }) {
    const emoji = categoryEmojis[item.categoryId] || '🍽️'

    return (
        <div className="dish-row" onClick={onToggle}>
            <div className="dish-emoji">{emoji}</div>
            <div className="dish-content">
                <div className="dish-header">
                    <span className="dish-name">{item.name}</span>
                    <span className="dish-price">{Number(item.price).toFixed(2)} kr</span>
                </div>
                <div className="dish-desc">{item.description}</div>
                <span className={`tag ${item.isAvailable ? 'tag-available' : 'tag-unavailable'}`}>
                    {item.isAvailable ? 'Tillgänglig' : 'Slut'}
                </span>
                {open && (
                    <div className="dish-expanded">
                        <strong>Kategori-ID:</strong> {item.categoryId}
                    </div>
                )}
            </div>
        </div>
    )
}
